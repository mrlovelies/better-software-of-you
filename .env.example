SOY_API_BASE_URL=https://soy-shared.pages.dev/api
SOY_OWNER_NAME=Your Name
SOY_OWNER_EMAIL=you@example.com
SOY_WORKSPACE_ROOT=~/wkspaces

# Telegram Bot (local — set via /telegram-setup)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Discord Bot (local — create at https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=
DISCORD_NUDGES_CHANNEL=nudges

# PayPal API (create app at https://developer.paypal.com/dashboard/applications)
# Use Live credentials, not Sandbox. Required scope: Transaction Search.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Wealthsimple (internal API — credentials for bearer token auth)
WEALTHSIMPLE_EMAIL=
WEALTHSIMPLE_PASSWORD=
