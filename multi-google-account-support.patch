@@ -0,0 +1,35 @@
+-- Multi-Google-Account Support
+-- Adds google_accounts table and account_id tracking on emails/calendar_events.
+-- All statements are idempotent.
+
+-- ═══════════════════════════════════════════════════════════════
+-- google_accounts: Track connected Google accounts
+-- ═══════════════════════════════════════════════════════════════
+
+CREATE TABLE IF NOT EXISTS google_accounts (
+    id INTEGER PRIMARY KEY AUTOINCREMENT,
+    email TEXT NOT NULL UNIQUE,
+    display_name TEXT,
+    token_file TEXT NOT NULL,
+    is_primary INTEGER NOT NULL DEFAULT 0,
+    connected_at TEXT NOT NULL DEFAULT (datetime('now')),
+    last_synced_at TEXT,
+    status TEXT NOT NULL DEFAULT 'active' CHECK (status IN ('active', 'paused', 'revoked'))
+);
+
+-- ═══════════════════════════════════════════════════════════════
+-- Add account_id to emails and calendar_events
+-- ═══════════════════════════════════════════════════════════════
+
+-- SQLite ALTER TABLE ADD COLUMN is idempotent-safe via IF NOT EXISTS workaround:
+-- If column already exists, the ALTER will fail silently (stderr suppressed by bootstrap.sh).
+
+ALTER TABLE emails ADD COLUMN account_id INTEGER REFERENCES google_accounts(id);
+ALTER TABLE calendar_events ADD COLUMN account_id INTEGER REFERENCES google_accounts(id);
+
+-- ═══════════════════════════════════════════════════════════════
+-- Indexes for efficient per-account queries
+-- ═══════════════════════════════════════════════════════════════
+
+CREATE INDEX IF NOT EXISTS idx_emails_account ON emails(account_id);
+CREATE INDEX IF NOT EXISTS idx_events_account ON calendar_events(account_id);
