#!/usr/bin/env bash
# cc — Claude Code wrapper with auto-handoff
#
# Usage: cc [any claude args]
#   cc                              → interactive session
#   cc --dangerously-skip-permissions → autonomous mode
#   cc -p "question"                → pipe mode (skips handoff)
#
# After an interactive session exits, generates a handoff summary
# and writes it to the SoY database. The summary is generated by
# Claude (pipe mode), but the DB write is done directly in bash
# so it can't be hallucinated or skipped.
#
# Install: /session-setup (creates ~/bin/cc symlink)

# Ensure nvm/node/claude are in PATH (needed on Linux/WSL2 machines)
[[ -s "$HOME/.nvm/nvm.sh" ]] && source "$HOME/.nvm/nvm.sh" 2>/dev/null

# Stay in the user's current directory — cc works from any project.
# Only fall back to SoY if launched from $HOME with no project context.
if [[ "$PWD" == "$HOME" ]] && [[ ! -f CLAUDE.md ]] && [[ ! -d .git ]]; then
    cd ~/.software-of-you
fi

SOY_DB="$HOME/.local/share/software-of-you/soy.db"
HOSTNAME=$(hostname -s 2>/dev/null || echo "unknown")

# Startup check: show active handoff if one exists
if command -v sqlite3 &>/dev/null && [[ -f "$SOY_DB" ]]; then
    handoff_info=$(sqlite3 "$SOY_DB" "SELECT source || ' · ' || datetime(created_at, 'localtime') FROM session_handoffs WHERE status='active' ORDER BY created_at DESC LIMIT 1" 2>/dev/null)
    if [[ -n "$handoff_info" ]]; then
        echo "↳ Active handoff from ${handoff_info} — run /pickup to resume"
    fi
fi

# Detect pipe mode — no handoff needed for one-shot queries
is_pipe_mode=false
for arg in "$@"; do
    if [[ "$arg" == "-p" || "$arg" == "--pipe" ]]; then
        is_pipe_mode=true
        break
    fi
done

# Run Claude with auto-accept permissions (cc = autonomous mode)
claude --dangerously-skip-permissions "$@"
exit_code=$?

# Skip handoff for pipe mode or if claude failed to start
if $is_pipe_mode || [[ $exit_code -ne 0 ]]; then
    exit $exit_code
fi

# --- Auto-handoff: bash handles structure, Claude only generates the summary ---

# Bail early if we can't write to the DB
if ! command -v sqlite3 &>/dev/null || [[ ! -f "$SOY_DB" ]]; then
    exit $exit_code
fi

echo ""
echo "Saving handoff..."

# Capture the handoff summary from Claude — all output goes to a temp file,
# nothing leaks to the terminal. The prompt is self-contained (no /handoff
# command dependency) so it works from any project directory.
handoff_tmp=$(mktemp)
trap 'rm -f "$handoff_tmp"' EXIT

BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")

read -r -d '' HANDOFF_PROMPT <<'PROMPT'
Generate a concise session handoff. Output ONLY the markdown below, nothing else — no preamble, no sign-off, no commentary.

## Session Handoff — [today's date]

### Done
- [what was accomplished this session]

### Remaining
- [what's unfinished or blocked]

### Key Files
- [files created or modified, grouped by purpose]

### Gotchas
- [anything surprising discovered]

### State
- Branch: [current branch]
- Uncommitted: [yes/no]
PROMPT

claude -p -c "$HANDOFF_PROMPT" > "$handoff_tmp" 2>/dev/null

# Validate we got something useful (at least 50 chars, contains "Done" or "Handoff")
handoff_content=$(cat "$handoff_tmp")
if [[ ${#handoff_content} -lt 50 ]] || ! echo "$handoff_content" | grep -qiE '(done|handoff|remaining|accomplished)'; then
    echo "Handoff skipped — session too short or summary generation failed."
    exit $exit_code
fi

# Write to file (local fallback)
mkdir -p tasks 2>/dev/null
cp "$handoff_tmp" tasks/handoff.md 2>/dev/null

# Write to DB — done entirely in bash, no hallucination possible
# Escape single quotes for SQL
safe_summary=$(echo "$handoff_content" | sed "s/'/''/g")

sqlite3 "$SOY_DB" "UPDATE session_handoffs SET status = 'expired' WHERE status = 'active';" 2>/dev/null
sqlite3 "$SOY_DB" "INSERT INTO session_handoffs (summary, project_ids, branch, source, status, created_at) VALUES ('${safe_summary}', NULL, '${BRANCH}', 'claude-code@${HOSTNAME}', 'active', datetime('now'));" 2>/dev/null

if [[ $? -eq 0 ]]; then
    last=$(sqlite3 "$SOY_DB" "SELECT datetime(created_at, 'localtime') FROM session_handoffs WHERE status='active' ORDER BY created_at DESC LIMIT 1" 2>/dev/null)
    echo "Handoff saved (${last})."
else
    echo "Handoff written to tasks/handoff.md but DB write failed."
fi

exit $exit_code
